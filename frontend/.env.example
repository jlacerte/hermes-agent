# Copilot UI (frontend Hermès) — variables d'environnement
# Copier ce fichier en `.env` (jamais commité) et remplir les valeurs.
# Les secrets NE doivent JAMAIS être dans le code ni dans git.

# ── PRODUCTION (popup réelle / page "/" → le vrai Philippe/Hermès) ──
HERMES_API_URL=http://10.0.0.1:8642/v1      # endpoint api_server d'Hermès
HERMES_API_KEY=                              # = API_SERVER_KEY d'Hermès (.hermes/.env)
HERMES_MODEL=hermes-agent                    # optionnel (défaut: hermes-agent)

# ── DÉVELOPPEMENT uniquement (page "/demo" des 5 piliers — échafaudage) ──
# Modèle neutre pour démontrer les piliers CopilotKit. NON requis en prod.
DEMO_OPENAI_API_KEY=                          # clé OpenAI (à roter si jamais exposée)
DEMO_MODEL=gpt-4o-mini
